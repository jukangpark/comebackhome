# ── 이 파일을 복사해 .env 로 만들고 값을 채우세요 (실제 .env 는 git 제외) ──

# Postgres
POSTGRES_USER=combackhome
POSTGRES_PASSWORD=change_me
POSTGRES_DB=combackhome
# api 컨테이너에서 db 서비스로 접속 (compose 네트워크 기준 host=db)
DATABASE_URL=postgres://combackhome:change_me@db:5432/combackhome

# API 서버
API_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string

# Meshy (P3에서 사용) — 이미 발급된 키
MESHY_API_KEY=msy_...

# Claude 헤드리스 채팅 (P5에서 사용)
# 로컬 Mac에서 `claude setup-token` 실행 후 발급된 토큰을 넣으세요
CLAUDE_CODE_OAUTH_TOKEN=
