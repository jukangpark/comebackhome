{
  "name": "combackhome",
  "version": "0.0.0",
  "private": true,
  "description": "반려동물 3D 채팅 웹앱 (MVP)",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "up": "docker compose up --build",
    "down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  }
}
